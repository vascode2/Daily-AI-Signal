# ── Gemini (summarization) ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Primary model, with a comma-separated fallback chain used on 404/429/5xx.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-flash-latest,gemini-2.0-flash,gemini-2.0-flash-lite,gemini-flash-lite-latest
# Per-request timeout in ms.
GEMINI_REQUEST_TIMEOUT_MS=120000
# Delay between Gemini calls (ms) to stay under free-tier rate limits.
GEMINI_DELAY_MS=5000

# ── Notion (publishing) ─────────────────────────────────────────
# Reuse the same integration token as your other digest projects.
NOTION_TOKEN=secret_or_ntn_token_here
# Parent page under which each day's digest is created as a child page.
# Run `npm run setup:notion` to create this page automatically.
NOTION_PAGE_ID=your_parent_page_id_here
# Title shown on the parent page.
NOTION_ROOT_TITLE=Daily AI Signal
# Notion API version (position param for newest-on-top requires >= 2026-03-11).
NOTION_VERSION=2026-03-11
# Set to true to skip Notion and only write the local Markdown file.
DIGEST_SKIP_NOTION=false

# ── Reddit (optional but recommended) ───────────────────────────
# Without these, the collector falls back to the public RSS feed (no scores /
# comment counts, and easily rate-limited). For reliable daily runs, create a
# "script" app at https://www.reddit.com/prefs/apps and paste the credentials.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=daily-ai-signal/0.1 by u/yourusername
# Delay between subreddit requests (ms). OAuth can be low; RSS should be higher.
REDDIT_DELAY_MS=2500
# RSS-only: max retries per subreddit request on 429/5xx.
REDDIT_RSS_RETRIES=2
# RSS-only: stop early after this many 429 subreddit failures in a row.
REDDIT_RSS_MAX_429_SUBS=3

# ── X / Twitter (optional, plugin-style) ───────────────────────
# Set `enabled: true` in config/sources.json when ready, and pick a mode:
#   mode=api        official X recent-search API (needs X_BEARER_TOKEN)
#   mode=playwright external scraper command that prints a JSON array to stdout
#   mode=fixture    load posts from a local JSON file (offline / CI / demo)
X_BEARER_TOKEN=
# Optional override; defaults to official API base (https://api.twitter.com/2).
X_API_BASE=
# mode=playwright uses an external command that prints a JSON array to stdout.
X_PLAYWRIGHT_COMMAND=
X_PLAYWRIGHT_TIMEOUT_MS=120000
# mode=fixture: path to a JSON array of posts (defaults to test/fixtures/x-sample.json).
X_FIXTURE_PATH=

# mode=grok uses your xAI/Grok API key with the built-in x_search tool.
# NOTE: this is a Grok (xAI) key, NOT a Twitter/X developer bearer token.
XAI_API_KEY=
# Optional: override the xAI API base and model.
XAI_API_BASE=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_REQUEST_TIMEOUT_MS=120000

# ── General ─────────────────────────────────────────────────────
# Timezone used for the digest date/heading (IANA name, e.g. America/New_York).
DIGEST_TIMEZONE=America/New_York
